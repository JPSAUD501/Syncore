{
  "name": "@syncore/react",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "build:deps": "pnpm --filter syncore build",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "pnpm run build:deps && vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "syncore": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  }
}
