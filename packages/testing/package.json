{
  "name": "@syncore/testing",
  "private": true,
  "type": "module",
  "dependencies": {
    "@syncore/core": "workspace:*",
    "@syncore/next": "workspace:*",
    "@syncore/platform-expo": "workspace:*",
    "@syncore/platform-node": "workspace:*",
    "@syncore/platform-web": "workspace:*",
    "@syncore/react": "workspace:*",
    "@syncore/schema": "workspace:*",
    "@syncore/svelte": "workspace:*",
    "syncorejs": "workspace:*"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "sql.js": "^1.14.1",
    "vitest": "^3.0.8"
  },
  "scripts": {
    "build": "node -e \"\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true});require('node:fs').rmSync('playwright-report',{recursive:true,force:true});require('node:fs').rmSync('test-results',{recursive:true,force:true})\"",
    "lint": "eslint playwright.config.ts src tests --ext .ts",
    "test": "vitest run --config vitest.config.ts",
    "test:smoke:electron": "bun run turbo run build --filter=syncore-example-electron && playwright test -c playwright.electron.config.ts",
    "test:smoke:expo": "tsx src/expo-smoke.ts",
    "test:smoke:web": "playwright test -c playwright.config.ts",
    "test:smoke": "bun run test:smoke:web && bun run test:smoke:electron && bun run test:smoke:expo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
