{
  "name": "syncorejs",
  "version": "0.2.2",
  "description": "Local-first reactive backend toolkit for offline apps",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "syncorejs": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JPSAUD501/Syncore.git",
    "directory": "packages/syncore"
  },
  "homepage": "https://github.com/JPSAUD501/Syncore#readme",
  "bugs": {
    "url": "https://github.com/JPSAUD501/Syncore/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "default": "./dist/cli.js",
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./components": {
      "default": "./dist/components.js",
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js"
    },
    "./browser": {
      "default": "./dist/browser.js",
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./browser/react": {
      "default": "./dist/browser-react.js",
      "types": "./dist/browser-react.d.ts",
      "import": "./dist/browser-react.js"
    },
    "./react": {
      "default": "./dist/react.js",
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./svelte": {
      "default": "./dist/svelte.js",
      "types": "./dist/svelte.d.ts",
      "import": "./dist/svelte.js"
    },
    "./expo": {
      "default": "./dist/expo.js",
      "types": "./dist/expo.d.ts",
      "import": "./dist/expo.js"
    },
    "./expo/react": {
      "default": "./dist/expo-react.js",
      "types": "./dist/expo-react.d.ts",
      "import": "./dist/expo-react.js"
    },
    "./node": {
      "default": "./dist/node.js",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./node/ipc": {
      "default": "./dist/node-ipc.js",
      "types": "./dist/node-ipc.d.ts",
      "import": "./dist/node-ipc.js"
    },
    "./node/ipc/react": {
      "default": "./dist/node-ipc-react.js",
      "types": "./dist/node-ipc-react.d.ts",
      "import": "./dist/node-ipc-react.js"
    },
    "./next": {
      "default": "./dist/next.js",
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./next/config": {
      "default": "./dist/next-config.js",
      "types": "./dist/next-config.d.ts",
      "import": "./dist/next-config.js"
    }
  },
  "scripts": {
    "build": "npm run build:deps && tsdown --config tsdown.config.ts && tsx ../../scripts/vendor-syncore-internals.ts",
    "build:deps": "npm run build --workspace @syncore/core && npm run build --workspace @syncore/schema && npm run build --workspace @syncore/devtools-protocol && npm run build --workspace @syncore/cli && npm run build --workspace @syncore/react && npm run build --workspace @syncore/platform-web && npm run build --workspace @syncore/platform-node && npm run build --workspace @syncore/platform-expo && npm run build --workspace @syncore/next && npm run build --workspace @syncore/svelte",
    "build:standalone": "npm run build",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "commander": "^14.0.3",
    "date-fns-tz": "^3.2.0",
    "node-sql-parser": "^5.4.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.22.3",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "expo-file-system": "^56.0.7",
    "expo-sqlite": "^56.0.4",
    "next": "^15.0.0 || ^16.0.0",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "expo-file-system": {
      "optional": true
    },
    "expo-sqlite": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@syncore/cli": "^0.1.0",
    "@syncore/core": "^0.1.0",
    "@syncore/devtools-protocol": "^0.1.0",
    "@syncore/next": "^0.1.0",
    "@syncore/platform-expo": "^0.1.0",
    "@syncore/platform-node": "^0.1.0",
    "@syncore/platform-web": "^0.1.0",
    "@syncore/react": "^0.1.0",
    "@syncore/schema": "^0.1.0",
    "@syncore/svelte": "^0.1.0",
    "expo-file-system": "^56.0.7",
    "expo-sqlite": "^56.0.4",
    "next": "16.3.0-canary.27"
  }
}
