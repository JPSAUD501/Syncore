{
  "name": "syncore-example-expo",
  "private": true,
  "scripts": {
    "syncorejs": "bunx tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts",
    "android:smoke": "expo run:android --variant release --no-bundler --app-id dev.syncore.expoexample",
    "build:deps": "bun run --filter syncorejs build:standalone",
    "clean": "node -e \"require('node:fs').rmSync('.expo',{recursive:true,force:true});require('node:fs').rmSync('android',{recursive:true,force:true})\"",
    "lint": "eslint App.tsx lib syncore --ext .ts,.tsx",
    "prelint": "bun run syncorejs:codegen",
    "prestart": "bun run syncorejs:codegen",
    "pretypecheck": "bun run syncorejs:codegen",
    "syncorejs:codegen": "bunx tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts codegen",
    "start": "expo start",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "expo": "^55.0.0",
    "react": "^19.0.0",
    "react-native": "^0.82.0",
    "syncorejs": "workspace:*"
  }
}
