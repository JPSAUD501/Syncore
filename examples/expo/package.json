{
  "name": "syncore-example-expo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "syncorejs": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts",
    "android:smoke": "expo run:android --variant release --no-bundler --app-id dev.syncore.expoexample",
    "build:deps": "npm run build:standalone --workspace syncorejs",
    "clean": "node -e \"require('node:fs').rmSync('.expo',{recursive:true,force:true});require('node:fs').rmSync('android',{recursive:true,force:true})\"",
    "dev": "turbo run dev:app --filter=syncore-example-expo",
    "dev:app": "npm run start",
    "dev:syncore": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts dev",
    "lint": "eslint App.tsx lib syncore --ext .ts,.tsx",
    "prelint": "npm run syncorejs:codegen",
    "prestart": "npm run syncorejs:codegen",
    "pretypecheck": "npm run syncorejs:codegen",
    "syncorejs:codegen": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts codegen",
    "start": "expo start",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "expo": "^55.0.0",
    "react": "^19.0.0",
    "react-native": "^0.82.0",
    "syncorejs": "^0.2.2"
  }
}
