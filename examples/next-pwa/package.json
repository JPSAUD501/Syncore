{
  "name": "syncore-example-next-pwa",
  "private": true,
  "type": "module",
  "scripts": {
    "syncore:dev": "bun run --cwd ../../packages/cli tsx src/index.ts dev",
    "syncore:codegen": "bun run --cwd ../../packages/cli tsx src/index.ts codegen",
    "build:deps": "bun run --filter syncore build:standalone",
    "dev": "bun run build:deps && bun run copy:sqljs-wasm && concurrently --kill-others-on-fail --names syncore,app --prefix-colors yellow,cyan \"bun run syncore:dev\" \"bun run dev:app\"",
    "dev:app": "next dev",
    "build": "bun run build:deps && bun run clean && bun run copy:sqljs-wasm && next build",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true});require('node:fs').rmSync('out',{recursive:true,force:true});require('node:fs').rmSync('public/sql-wasm.wasm',{force:true})\"",
    "copy:sqljs-wasm": "node ./scripts/copy-sqljs-wasm.mjs",
    "lint": "eslint app syncore next.config.ts --ext .ts,.tsx --ignore-pattern app/syncore.worker.js",
    "prebuild": "bun run syncore:codegen",
    "predev": "bun run syncore:codegen",
    "prelint": "bun run syncore:codegen",
    "pretypecheck": "bun run syncore:codegen",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@syncore/next": "workspace:*",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.13.0",
    "syncore": "workspace:*"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
