{
  "name": "syncore-example-next-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "syncorejs": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts",
    "syncorejs:dev": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts dev",
    "syncorejs:codegen": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts codegen",
    "syncorejs:migrate:generate": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts migrate generate init_planner",
    "build:deps": "npm run build:standalone --workspace syncorejs",
    "dev": "turbo run dev:app --filter=syncore-example-next-pwa",
    "dev:app": "npm run copy:sqljs-wasm && next dev",
    "dev:syncore": "npm run syncorejs:dev",
    "build": "npm run clean && npm run copy:sqljs-wasm && next build",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true});require('node:fs').rmSync('out',{recursive:true,force:true});require('node:fs').rmSync('public/sql-wasm.wasm',{force:true})\"",
    "copy:sqljs-wasm": "node ./scripts/copy-sqljs-wasm.mjs",
    "lint": "eslint app syncore next.config.mjs --ext .ts,.tsx,.mjs",
    "prebuild": "npm run syncorejs:codegen",
    "predev": "npm run syncorejs:codegen",
    "prelint": "npm run syncorejs:codegen",
    "pretest": "npm run syncorejs:codegen",
    "pretypecheck": "npm run syncorejs:codegen",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.13.0",
    "syncorejs": "^0.2.2"
  },
  "devDependencies": {
    "vitest": "^3.0.8"
  }
}
