{
  "name": "syncore-example-sveltekit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "syncorejs": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts",
    "syncorejs:dev": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts dev",
    "syncorejs:codegen": "tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts codegen",
    "build:deps": "npm run build:standalone --workspace syncorejs",
    "dev": "turbo run dev:app --filter=syncore-example-sveltekit",
    "dev:app": "vite dev",
    "dev:syncore": "npm run syncorejs:dev",
    "build": "npm run syncorejs:codegen && vite build",
    "typecheck": "npm run syncorejs:codegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "sql.js": "^1.13.0",
    "svelte": "^5.0.0",
    "syncorejs": "^0.2.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.4.1"
  }
}
