{
  "name": "syncore-example-electron",
  "private": true,
  "type": "module",
  "main": "./dist/src/main.js",
  "scripts": {
    "syncore:dev": "bun run --cwd ../../packages/cli tsx src/index.ts dev",
    "build:deps": "bun run --filter syncore build:standalone",
    "dev": "concurrently --kill-others-on-fail --names syncore,app --prefix-colors yellow,cyan \"bun run syncore:dev\" \"bun run dev:app\"",
    "dev:app": "bun run build && electron ./dist/src/main.js",
    "build": "bun run build:deps && bun run build:main && bun run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && node ./scripts/copy-preload.mjs",
    "build:renderer": "vite build --config vite.renderer.config.ts && node ./scripts/fix-renderer-html.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"syncore/**/*.ts\"",
    "prebuild": "bun run syncore:codegen",
    "predev": "bun run syncore:codegen",
    "prelint": "bun run syncore:codegen",
    "pretypecheck": "bun run syncore:codegen",
    "syncore:codegen": "bun run --cwd ../../packages/cli tsx src/index.ts codegen",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@syncore/react": "workspace:*",
    "syncore": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.3.2",
    "typescript": "^5.8.2",
    "vite": "^6.4.1"
  },
  "trustedDependencies": [
    "electron"
  ]
}
