{
  "name": "syncore-example-electron",
  "private": true,
  "type": "module",
  "main": "./dist/examples/electron/src/main.js",
  "scripts": {
    "syncorejs": "bunx tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts",
    "syncorejs:dev": "bunx tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts dev",
    "build:deps": "bun run --filter syncorejs build:standalone",
    "dev": "turbo run dev:app --filter=syncore-example-electron",
    "dev:app": "bun run build && electron ./dist/examples/electron/src/main.js",
    "dev:syncore": "bun run syncorejs:dev",
    "build": "bun run build:main && bun run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && node ./scripts/copy-preload.mjs",
    "build:renderer": "vite build --config vite.renderer.config.ts && node ./scripts/fix-renderer-html.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"syncore/**/*.ts\"",
    "prebuild": "bun run syncorejs:codegen",
    "predev": "bun run syncorejs:codegen",
    "prelint": "bun run syncorejs:codegen",
    "pretypecheck": "bun run syncorejs:codegen",
    "syncorejs:codegen": "bunx tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts codegen",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "syncorejs": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^36.3.2",
    "typescript": "^5.8.2",
    "vite": "^6.4.1"
  },
  "trustedDependencies": [
    "electron"
  ]
}
