{
  "name": "syncore-example-browser-esm",
  "private": true,
  "type": "module",
  "scripts": {
    "syncore:dev": "pnpm --dir ../../packages/cli exec tsx src/index.ts dev",
    "build:deps": "pnpm --filter syncore build:standalone",
    "build": "pnpm run build:deps && vite build",
    "dev": "pnpm run build:deps && concurrently --kill-others-on-fail --names syncore,app --prefix-colors yellow,cyan \"pnpm run syncore:dev\" \"pnpm run dev:app\"",
    "dev:app": "vite"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.13.0",
    "syncore": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.4.1"
  }
}
