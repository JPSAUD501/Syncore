{
  "name": "syncore-example-browser-esm",
  "private": true,
  "type": "module",
  "scripts": {
    "syncorejs:dev": "bunx tsx --tsconfig ../../packages/cli/tsconfig.json ../../packages/cli/src/index.ts dev",
    "build:deps": "bun run --filter syncorejs build:standalone",
    "build": "bun run build:deps && vite build",
    "dev": "bun run build:deps && concurrently --kill-others-on-fail --names syncore,app --prefix-colors yellow,cyan \"bun run syncorejs:dev\" \"bun run dev:app\"",
    "dev:app": "vite"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.13.0",
    "syncorejs": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.4.1"
  }
}
