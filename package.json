{
  "name": "syncore-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Syncore monorepo",
  "packageManager": "npm@11.15.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "api:check": "node ./scripts/run-api-extractor.mjs",
    "api:update": "node ./scripts/run-api-extractor.mjs --local",
    "build": "turbo run build --concurrency=2",
    "changeset": "changeset",
    "changeset:auto:syncore": "node ./scripts/create-auto-syncore-changeset.mjs",
    "changeset:beta:enter": "changeset pre enter beta",
    "changeset:beta:exit": "changeset pre exit",
    "changeset:beta:publish": "node ./scripts/ensure-changeset-prerelease.mjs beta && changeset publish",
    "changeset:beta:version": "node ./scripts/ensure-changeset-prerelease.mjs beta && changeset version",
    "dev": "turbo run dev",
    "lint": "turbo run lint --concurrency=2",
    "test": "turbo run test --concurrency=1",
    "test:smoke": "npm run test:smoke --workspace @syncore/testing",
    "typecheck": "turbo run typecheck --concurrency=2",
    "validate:pack:syncore": "tsx ./scripts/validate-syncore-package.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean --parallel",
    "syncorejs:dev": "syncorejs dev",
    "syncorejs:codegen": "syncorejs codegen"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "unrun": "^0.3.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "next": {
      "postcss": "^8.5.10"
    },
    "xcode": {
      "uuid": "^11.1.1"
    }
  }
}
