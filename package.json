{
  "name": "syncore-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Syncore monorepo",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "api:check": "node ./scripts/run-api-extractor.mjs",
    "api:update": "node ./scripts/run-api-extractor.mjs --local",
    "build": "turbo run build --concurrency=2",
    "changeset": "changeset",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint --concurrency=2",
    "test": "turbo run test --concurrency=2",
    "test:smoke": "bun run --filter @syncore/testing test:smoke",
    "typecheck": "turbo run typecheck --concurrency=2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean --parallel"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.22.0",
    "@microsoft/api-extractor": "^7.52.11",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.0.15",
    "tsdown": "^0.21.0",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
